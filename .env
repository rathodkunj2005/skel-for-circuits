# ─────────────────────────────────────────────────────────────────────────────
# skel-for-circuits — environment variables
# Copy this file to .env and fill in the values you need.
# The only mandatory variable for the Ollama path is USE_OLLAMA=true.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama (local, no API key required) ──────────────────────────────────────
# Set to "true" to route ALL LLM calls through a local Ollama instance.
# When this is true, OPENAI_API_KEY is not required.
USE_OLLAMA=true

# URL of the Ollama OpenAI-compatible API (default shown — change if you run
# Ollama on a different host/port).
OLLAMA_BASE_URL=http://localhost:11434/v1

# Which Ollama model to use. Run `ollama list` to see what you have pulled.
# Recommended: gemma3:4b (fast, low VRAM), llama3.2:3b, mistral:7b
OLLAMA_MODEL=gemma3:4b

# ── OpenAI (cloud, closed-source path) ───────────────────────────────────────
# Only needed when USE_OLLAMA=false and you are NOT passing
# --open_source_grouping / --open_source_labeling flags.
# OPENAI_API_KEY=sk-...
